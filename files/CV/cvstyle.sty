\ProvidesPackage{cvstyle}

%% ---------------------------- PACKAGES ----------------------------
\usepackage[margin=1in]{geometry} 
\usepackage{hyperref} 
\usepackage{titlesec} 
\usepackage{enumitem} 
\usepackage{setspace} 


%% --------------------------- FORMATTING ---------------------------
%% Page and paragraph settings
\pagestyle{empty}             % Remove page numbers
\setlength{\parindent}{0pt}   % Remove paragraph indentation
\setstretch{1.1}              % Set line spacing
\setlist[itemize]{            % Custom list spacing
	leftmargin=3.5em, 
	noitemsep, 
	topsep=2pt, 
	parsep=2pt
}   


%% Clickable link options
\hypersetup{                 
	colorlinks=true,
	linkcolor=blue,
	filecolor=magenta,      
	urlcolor=blue,
}

%% Section header formatting
\titleformat{\section}{\large\bfseries\uppercase}{}{0em}{}[\titlerule]
\titlespacing{\section}{0pt}{14pt}{12pt}


%% ------------------------- BIBLIOGRAPHY ---------------------------
\usepackage[
	backend=biber, 
	style=numeric, 
	sorting=ydnt, 
	url=false, 
	isbn=false,
	maxbibnames=99,
	eprint=false
]{biblatex}
\addbibresource{publications.bib}

%% ------------------------ CUSTOM COMMANDS -------------------------
%% Command to bold my name in citations
\newcommand{\me}[1]{\textbf{#1}}

%% Custom indent tab
\newcommand{\tab}{\hspace*{15pt}}

